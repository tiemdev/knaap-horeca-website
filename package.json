{
  "name": "knaap",
  "private": true,
  "homepage": "https://tiemdev.github.io/knaap-horeca-website/",
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:strapi\"",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "dev:strapi": "npm --prefix apps/strapi run develop",
    "build:frontend": "npm --workspace apps/frontend run build",
    "build:strapi": "npm --prefix apps/strapi run build"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}